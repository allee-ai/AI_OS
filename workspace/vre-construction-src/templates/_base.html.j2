{# Base template: head, sticky nav, footer, full design system CSS.
   Child templates override blocks: title, description, canonical, jsonld,
   og_image, body_class, content.
#}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}{{ site.brand.name }}{% endblock %}</title>
<meta name="description" content="{% block description %}{{ site.brand.name }} — residential electrical work in {{ site.brand.city }}.{% endblock %}">
<link rel="canonical" href="{% block canonical %}https://vre-construction.com/{{ this_page }}{% endblock %}">
<meta name="theme-color" content="{{ site.theme_color }}">
<meta name="robots" content="index, follow">
<meta property="og:type" content="website">
<meta property="og:url" content="https://vre-construction.com/{{ this_page }}">
<meta property="og:title" content="{{ self.title() }}">
<meta property="og:description" content="{{ self.description() }}">
<meta property="og:site_name" content="{{ site.brand.name }}">
{% block og_image %}{% endblock %}
<meta name="twitter:card" content="summary_large_image">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="{{ site.fonts }}" rel="stylesheet">
{% block jsonld %}{% endblock %}
<style>
/* ===== Design tokens =================================================== */
:root{
  --bg:#ffffff;
  --bg-2:#faf7f2;            /* warm cream alt band */
  --bg-3:#1a1429;            /* deep ink inverted band */
  --fg:#1a1429;              /* deep ink, not pure black */
  --fg-on-dark:#f7f4fb;
  --mute:#5b5478;
  --mute-on-dark:#b8b0d0;
  --dim:#8c849f;
  --accent:#7c3aed;
  --accent-hover:#6d28d9;
  --accent-2:#ec4899;
  --amber:#f59e0b;
  --rule:rgba(26,20,41,0.08);
  --rule-strong:rgba(26,20,41,0.16);
  --card:#ffffff;
  --card-shadow:0 1px 2px rgba(26,20,41,0.04), 0 8px 24px rgba(26,20,41,0.05);
  --card-shadow-hover:0 2px 4px rgba(124,58,237,0.08), 0 16px 40px rgba(26,20,41,0.10);
  /* 5-stop structural gradient — topbar only */
  --grad-topbar:linear-gradient(90deg,#7c3aed 0%,#c026d3 30%,#ec4899 55%,#f59e0b 80%,#22d3ee 100%);
  /* 3-stop warm gradient — body usage (underlines, accents, CTA hover) */
  --grad:linear-gradient(90deg,#7c3aed 0%,#ec4899 55%,#f59e0b 100%);
  --grad-soft:linear-gradient(90deg,rgba(124,58,237,0.14) 0%,rgba(236,72,153,0.14) 55%,rgba(245,158,11,0.14) 100%);
  --mono:'JetBrains Mono',ui-monospace,SFMono-Regular,Menlo,monospace;
  --sans:'Inter',system-ui,-apple-system,Segoe UI,sans-serif;
  --serif:'Fraunces',Georgia,serif;
  --maxw:64rem;
  --maxw-narrow:48rem;
}

/* ===== Reset / base ==================================================== */
*{box-sizing:border-box}
html{scroll-behavior:smooth}
@media (prefers-reduced-motion: reduce){
  html{scroll-behavior:auto}
  *,*::before,*::after{animation-duration:.001ms !important;transition-duration:.001ms !important}
}
html,body{margin:0;padding:0}
body{
  background:var(--bg);color:var(--fg);
  font-family:var(--sans);font-size:17px;line-height:1.7;
  -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;
}
img{max-width:100%;display:block}
a{color:var(--accent);text-decoration:none;transition:color .15s ease, opacity .15s ease}
a:hover{color:var(--accent-hover)}
:focus{outline:none}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:3px}

/* Tabular numerals everywhere a number appears in tables/stats/prices */
.mono, .num, td.price, .stat-num, .price-inline{
  font-family:var(--mono);font-feature-settings:"tnum","ss01";
}

/* ===== Topbar (structural 5-stop gradient, always present) ============= */
.topbar{height:3px;background:var(--grad-topbar);width:100%;position:relative;z-index:50}

/* ===== Sticky nav ===================================================== */
.nav-shell{
  position:sticky;top:0;z-index:40;
  background:rgba(255,255,255,0.85);
  backdrop-filter:saturate(160%) blur(14px);
  -webkit-backdrop-filter:saturate(160%) blur(14px);
  border-bottom:1px solid transparent;
  transition:border-color .2s ease, background .2s ease, padding .2s ease;
}
.nav-shell.scrolled{
  background:rgba(255,255,255,0.94);
  border-bottom-color:var(--rule);
}
.nav{
  max-width:var(--maxw);margin:0 auto;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.1rem 1.5rem;
  transition:padding .2s ease;
}
.nav-shell.scrolled .nav{padding:.7rem 1.5rem}
.brand-mark{display:flex;align-items:center;gap:.65rem;color:var(--fg)}
.brand-mark:hover{color:var(--fg)}
.brand-mark .dot{
  width:10px;height:10px;border-radius:50%;
  background:var(--grad);
  box-shadow:0 0 0 4px rgba(124,58,237,0.10);
  flex-shrink:0;
}
.brand-mark .name{font-weight:700;letter-spacing:-0.01em;font-size:1rem;line-height:1.1}
.brand-mark .name small{
  display:block;color:var(--mute);font-weight:500;font-size:0.7rem;
  letter-spacing:0.10em;text-transform:uppercase;margin-top:0.15rem;
}
.nav-links{display:flex;align-items:center;gap:1.6rem}
.nav-links a{color:var(--mute);font-size:.94rem;font-weight:500}
.nav-links a:hover,.nav-links a.on{color:var(--fg)}
.nav-links a.on{position:relative}
.nav-links a.on::after{
  content:"";position:absolute;left:0;right:0;bottom:-6px;height:2px;
  background:var(--grad);border-radius:2px;
}
.nav-cta{
  display:inline-flex;align-items:center;gap:.4rem;
  background:var(--fg);color:#fff;padding:.55rem 1rem;border-radius:8px;
  font-size:.88rem;font-weight:600;letter-spacing:.005em;
  transition:transform .15s ease, box-shadow .15s ease, background .15s ease;
}
.nav-cta:hover{background:var(--accent);color:#fff;transform:translateY(-1px);box-shadow:0 6px 16px rgba(124,58,237,0.25)}
.nav-cta::after{content:"→";transition:transform .15s ease}
.nav-cta:hover::after{transform:translateX(2px)}
@media (max-width:720px){
  .nav-links{gap:1rem}
  .nav-links a:not(.nav-cta){display:none}
}

/* ===== Layout ========================================================== */
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 1.5rem}
.wrap-narrow{max-width:var(--maxw-narrow);margin:0 auto;padding:0 1.5rem}
.band{padding:5rem 0}
.band-tight{padding:3.5rem 0}
.band-2{background:var(--bg-2)}
.band-dark{background:var(--bg-3);color:var(--fg-on-dark)}
.band-dark a{color:#fff}
.band-dark .sub{color:var(--mute-on-dark)}

/* ===== Type =========================================================== */
h1,h2,h3,h4{margin:0;letter-spacing:-0.02em}
h1{
  font-family:var(--serif);font-weight:500;
  font-size:clamp(2.4rem,6vw,4rem);line-height:1.05;letter-spacing:-0.035em;
}
h2{
  font-family:var(--serif);font-weight:500;
  font-size:clamp(1.6rem,3.4vw,2.2rem);line-height:1.15;
  margin-bottom:.6rem;
  scroll-margin-top:6rem;
}
h3{
  font-family:var(--sans);font-weight:600;
  font-size:1.05rem;color:var(--accent);
  letter-spacing:.005em;
  margin:1.75rem 0 .5rem;
}
h4{
  font-family:var(--sans);font-weight:600;
  font-size:.78rem;letter-spacing:.10em;text-transform:uppercase;
  color:var(--accent);
}
p{margin:0 0 1rem}
.lede{font-size:1.2rem;line-height:1.6;color:var(--fg);max-width:42rem}
.sub{color:var(--mute)}
.eyebrow{
  display:inline-block;font-family:var(--sans);font-weight:600;
  font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;
  color:var(--accent);margin-bottom:1rem;
}
.eyebrow::before{content:"";display:inline-block;width:1.5rem;height:2px;background:var(--grad);vertical-align:middle;margin-right:.6rem;border-radius:2px}

/* Underlined gradient accent — replaces fill gradient on words */
.grad-under{
  font-family:var(--serif);font-style:italic;font-weight:500;
  position:relative;display:inline-block;white-space:nowrap;
}
.grad-under::after{
  content:"";position:absolute;left:-0.05em;right:-0.05em;bottom:0.10em;
  height:0.28em;background:var(--grad);
  z-index:-1;border-radius:3px;opacity:.85;
}
/* Pure-gradient text — used sparingly (CTA word, footer mark) */
.grad-text{
  background:var(--grad);-webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
}

/* Headline-anchor copy-link affordance */
h2[id]{position:relative}
h2[id] .anchor{
  position:absolute;left:-1.4em;top:0;opacity:0;color:var(--accent);
  font-family:var(--sans);font-weight:500;text-decoration:none;
  transition:opacity .15s ease;
}
h2[id]:hover .anchor,h2[id] .anchor:focus-visible{opacity:.6}

/* ===== Buttons ======================================================== */
.btn{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.95rem 1.5rem;border-radius:10px;
  font-family:var(--sans);font-weight:600;font-size:1rem;letter-spacing:.005em;
  border:1px solid transparent;cursor:pointer;
  transition:transform .15s ease, box-shadow .15s ease, background .15s ease, color .15s ease;
}
.btn-primary{background:var(--fg);color:#fff}
.btn-primary:hover{background:var(--accent);color:#fff;transform:translateY(-1px);box-shadow:0 10px 24px rgba(124,58,237,0.28)}
.btn-primary::after{content:"→";transition:transform .15s ease}
.btn-primary:hover::after{transform:translateX(3px)}
.btn-ghost{background:transparent;color:var(--fg);border-color:var(--rule-strong)}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent)}

/* CTA cluster (button + microcopy underneath) */
.cta-cluster{display:flex;flex-direction:column;align-items:flex-start;gap:.55rem}
.cta-cluster.center{align-items:center;text-align:center}
.cta-micro{color:var(--mute);font-size:.85rem;letter-spacing:.005em}

/* ===== Hero =========================================================== */
.hero{padding:5.5rem 0 4rem;position:relative;overflow:hidden}
.hero::before{
  content:"";position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 60% 50% at 85% 0%,rgba(245,158,11,0.10) 0%,transparent 60%),
    radial-gradient(ellipse 70% 60% at 0% 30%,rgba(124,58,237,0.10) 0%,transparent 65%);
  z-index:-1;
}
.hero h1{max-width:18ch;margin-bottom:1.25rem}
.hero .lede{margin-bottom:2rem}
.hero-cta-row{display:flex;flex-wrap:wrap;gap:1rem;align-items:center;margin-top:1.5rem}

/* ===== Stat strip ===================================================== */
.stats{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
  margin:3rem 0 0;padding:1.6rem 0;
  border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);
}
.stats .stat{padding:.25rem 1.25rem;border-left:1px solid var(--rule)}
.stats .stat:first-child{border-left:0;padding-left:0}
.stat-num{font-family:var(--mono);font-weight:600;font-size:1.6rem;color:var(--fg);letter-spacing:-.02em;line-height:1.1}
.stat-label{font-size:.82rem;color:var(--mute);margin-top:.25rem;letter-spacing:.01em}
@media (max-width:680px){
  .stats{grid-template-columns:repeat(2,1fr);gap:1.25rem 0;padding:1.25rem 0}
  .stats .stat{padding:.5rem 1rem;border-left:0;border-top:1px solid var(--rule);padding-top:1rem}
  .stats .stat:first-child,.stats .stat:nth-child(2){border-top:0;padding-top:.5rem}
}

/* ===== Three-step "How it works" ====================================== */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:2.5rem}
@media (max-width:760px){.steps{grid-template-columns:1fr;gap:1.5rem}}
.step{padding:0}
.step .num{
  display:inline-flex;align-items:center;justify-content:center;
  width:2.4rem;height:2.4rem;border-radius:50%;
  background:var(--grad-soft);color:var(--accent);
  font-family:var(--mono);font-weight:600;font-size:1rem;
  margin-bottom:1rem;
  border:1px solid rgba(124,58,237,0.18);
}
.step h3{color:var(--fg);font-family:var(--serif);font-weight:600;font-style:normal;font-size:1.25rem;margin:.25rem 0 .5rem;letter-spacing:-.01em}
.step p{color:var(--mute);font-size:.96rem;margin:0}

/* ===== Service pillars (3-up) ======================================== */
.pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:2.5rem}
@media (max-width:840px){.pillars{grid-template-columns:1fr}}
.pillar{
  display:flex;flex-direction:column;
  padding:1.75rem;background:var(--card);
  border:1px solid var(--rule);border-radius:14px;
  box-shadow:var(--card-shadow);
  transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease;
}
.pillar:hover{transform:translateY(-3px);box-shadow:var(--card-shadow-hover);border-color:rgba(124,58,237,0.25)}
.pillar h3{font-family:var(--serif);font-weight:600;font-style:normal;font-size:1.3rem;color:var(--fg);margin:0 0 .5rem;letter-spacing:-.01em}
.pillar p{color:var(--mute);font-size:.95rem;flex:1;margin:0 0 1rem}
.pillar .price-inline{color:var(--accent);font-weight:600;font-size:.95rem;margin-bottom:1rem}
.pillar .more{color:var(--accent);font-weight:600;font-size:.9rem;display:inline-flex;align-items:center;gap:.35rem;align-self:flex-start}
.pillar .more::after{content:"→";transition:transform .15s ease}
.pillar:hover .more::after{transform:translateX(3px)}

/* ===== Photo band ===================================================== */
.photo-band{position:relative;height:clamp(280px,38vw,440px);overflow:hidden;margin:0}
.photo-band img{width:100%;height:100%;object-fit:cover;filter:saturate(0.85) contrast(1.05)}
.photo-band::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(26,20,41,0.05) 0%,rgba(26,20,41,0.35) 100%),
             linear-gradient(120deg,rgba(124,58,237,0.20) 0%,transparent 50%,rgba(245,158,11,0.18) 100%);
  mix-blend-mode:multiply;
}
.photo-band .photo-caption{
  position:absolute;left:0;right:0;bottom:0;padding:1.25rem 1.5rem;
  color:#fff;font-size:.85rem;letter-spacing:.03em;
  z-index:2;text-shadow:0 1px 4px rgba(0,0,0,0.4);
  max-width:var(--maxw);margin:0 auto;
}

/* ===== Testimonials =================================================== */
.quotes{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:2.5rem}
@media (max-width:840px){.quotes{grid-template-columns:1fr}}
.quote{
  padding:1.75rem;background:var(--card);
  border:1px solid var(--rule);border-radius:14px;
  box-shadow:var(--card-shadow);
}
.quote blockquote{margin:0 0 1rem;color:var(--fg);font-size:1.02rem;line-height:1.55;font-family:var(--serif);font-weight:500;font-style:italic;letter-spacing:-.005em}
.quote blockquote::before{content:"\201C";font-size:2.2rem;color:var(--accent);line-height:0;vertical-align:-0.35em;margin-right:.2rem;font-family:var(--serif);font-style:normal}
.quote .who{display:flex;flex-direction:column;font-size:.85rem;color:var(--mute);border-top:1px solid var(--rule);padding-top:.85rem}
.quote .who strong{color:var(--fg);font-weight:600}

/* ===== Promise / values band ========================================= */
.values{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:2rem}
@media (max-width:760px){.values{grid-template-columns:1fr;gap:1.25rem}}
.value h3{color:var(--fg);font-family:var(--serif);font-weight:600;font-style:normal;font-size:1.2rem;margin:0 0 .5rem;letter-spacing:-.01em}
.value p{color:var(--mute);font-size:.95rem;margin:0}

/* ===== Bottom CTA band =============================================== */
.cta-band{padding:4.5rem 0;text-align:center}
.cta-band h2{font-size:clamp(1.8rem,4vw,2.6rem);max-width:24ch;margin:0 auto .8rem;color:#fff}
.cta-band .lede{color:var(--mute-on-dark);max-width:36rem;margin:0 auto 2rem}
.cta-band .btn-primary{background:#fff;color:var(--fg)}
.cta-band .btn-primary:hover{background:var(--accent);color:#fff}
.cta-band .cta-micro{color:var(--mute-on-dark)}

/* ===== Footer ======================================================== */
footer.site{
  border-top:1px solid var(--rule);
  padding:2.5rem 0 3rem;
  background:var(--bg);
  font-size:.88rem;color:var(--mute);
}
footer.site .row{
  max-width:var(--maxw);margin:0 auto;padding:0 1.5rem;
  display:flex;justify-content:space-between;align-items:flex-start;
  gap:2rem;flex-wrap:wrap;
}
footer.site .meta{display:flex;flex-direction:column;gap:.35rem}
footer.site .meta strong{color:var(--fg);font-size:.95rem;font-weight:600}
footer.site .links{display:flex;gap:1.25rem;flex-wrap:wrap}
footer.site .links a{color:var(--mute);font-size:.88rem}
footer.site .links a:hover{color:var(--accent)}
footer.site .credit{flex-basis:100%;border-top:1px solid var(--rule);padding-top:1rem;display:flex;justify-content:space-between;flex-wrap:wrap;gap:.5rem;color:var(--dim);font-size:.8rem}
footer.site .credit a{color:var(--mute)}

/* ===== Content-page primitives (used by pricing.html & others) ======= */
.content-h1-block h1{max-width:22ch;margin-bottom:1.25rem}
.content-h1-block .lede{margin-bottom:1.5rem}

.toc{
  margin:2.5rem 0;padding:1.4rem 1.6rem;
  background:var(--bg-2);border:1px solid var(--rule);
  border-left:3px solid var(--accent);border-radius:10px;
}
.toc h4{margin:0 0 .6rem;color:var(--accent)}
.toc ol{margin:0;padding-left:1.25rem;color:var(--mute);font-size:.95rem;columns:2;column-gap:2rem}
.toc li{margin-bottom:.3rem;break-inside:avoid}
.toc a{color:var(--mute);font-weight:500}
.toc a:hover{color:var(--accent)}
@media (max-width:560px){.toc ol{columns:1}}

.section{padding:2.5rem 0;border-top:1px solid var(--rule)}
.section:first-of-type{border-top:0;padding-top:1.5rem}
.section h2 .num{
  font-family:var(--mono);font-weight:500;font-style:normal;
  color:var(--accent);font-size:.75em;
  margin-right:.7rem;vertical-align:.15em;letter-spacing:.02em;
}

.callout{
  margin:1.5rem 0;padding:1.1rem 1.4rem;
  background:var(--bg-2);border:1px solid var(--rule);
  border-left:3px solid var(--accent);border-radius:10px;
  font-size:.96rem;
}
.callout strong{color:var(--accent)}

.warn{
  margin:1.5rem 0;padding:1.1rem 1.4rem;
  background:#fff7ed;border:1px solid #fed7aa;
  border-left:3px solid var(--amber);border-radius:10px;
  font-size:.96rem;color:#7c2d12;
}
.warn strong{color:#9a3412}

.kv{
  display:grid;grid-template-columns:max-content 1fr;
  gap:.55rem 1.4rem;margin:1.2rem 0;padding:1.2rem 1.4rem;
  background:var(--card);border:1px solid var(--rule);border-radius:10px;
  font-size:.96rem;
}
.kv dt{color:var(--accent);font-weight:600;font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;padding-top:.1rem}
.kv dd{margin:0;color:var(--fg)}
@media (max-width:560px){.kv{grid-template-columns:1fr;gap:.15rem 0}.kv dt{margin-top:.6rem}.kv dt:first-child{margin-top:0}}

ul.bullets,ol.bullets{margin:.5rem 0 1rem;padding-left:1.2rem;color:var(--fg)}
ul.bullets li,ol.bullets li{margin-bottom:.45rem}
ul.bullets li::marker,ol.bullets li::marker{color:var(--accent)}
ul.bullets li strong,ol.bullets li strong{color:var(--fg)}

.table-wrap{margin:1.5rem 0;overflow-x:auto;border:1px solid var(--rule);border-radius:10px;background:var(--card);box-shadow:var(--card-shadow)}
table{width:100%;border-collapse:collapse;font-size:.95rem;min-width:32rem}
th,td{padding:.85rem 1.1rem;text-align:left;border-bottom:1px solid var(--rule);vertical-align:top}
th{background:var(--bg-2);color:var(--fg);font-weight:600;font-size:.74rem;text-transform:uppercase;letter-spacing:.08em;white-space:nowrap}
td:first-child{color:var(--fg);font-weight:500}
td.price{color:var(--accent);font-weight:600;white-space:nowrap;font-family:var(--mono);font-feature-settings:"tnum"}
tr:last-child td{border-bottom:0}
tbody tr{transition:background .12s ease}
tbody tr:hover{background:var(--bg-2)}

.cta-mini{
  margin-top:1.5rem;padding:1.25rem 1.5rem;
  background:linear-gradient(135deg,var(--bg-2) 0%,#fff 100%);
  border:1px solid var(--rule-strong);border-radius:12px;font-size:1rem;
}
.cta-mini a{color:var(--accent);font-weight:600}

.legend{
  display:flex;flex-wrap:wrap;gap:1.6rem;
  margin:1.5rem 0 0;padding:1rem 1.3rem;
  background:var(--bg-2);border:1px solid var(--rule);border-radius:10px;
  font-size:.88rem;color:var(--mute);
}
.legend strong{color:var(--fg);font-weight:600}

.two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin:1.5rem 0}
@media (max-width:640px){.two-col{grid-template-columns:1fr}}
.two-col .col{padding:1.25rem 1.4rem;background:var(--card);border:1px solid var(--rule);border-radius:10px;box-shadow:var(--card-shadow)}
.two-col .col h4{margin:0 0 .7rem;color:var(--accent)}
.two-col .col.up h4{color:#be185d}
.two-col .col.down h4{color:#047857}
.two-col .col ul{margin:0;padding-left:1.1rem;font-size:.93rem;color:var(--fg)}
.two-col .col li{margin-bottom:.35rem}

.hero-promise{
  margin:1.5rem 0 2rem;padding:1.5rem 1.7rem;
  background:linear-gradient(135deg,var(--bg-2) 0%,#fff 100%);
  border:1px solid var(--rule-strong);border-radius:14px;
}
.hero-promise h3{margin:0 0 .6rem}
.hero-promise p{margin:0 0 .6rem;font-size:1rem}
.hero-promise p:last-child{margin-bottom:0}

.tag-row{display:flex;flex-wrap:wrap;gap:.5rem;margin:.5rem 0 1.5rem}
.tag-row span{
  font-size:.78rem;color:var(--mute);
  background:var(--bg-2);border:1px solid var(--rule);
  padding:.35rem .75rem;border-radius:999px;
}
.tag-row span strong{color:var(--fg);font-weight:600}

/* ===== Print ========================================================= */
@media print{
  .nav-shell,.cta-band,footer.site,.photo-band{display:none !important}
  body{background:#fff;color:#000}
  a{color:#000;text-decoration:underline}
  .topbar{height:2px;background:#000}
  .table-wrap,.callout,.warn,.kv,.cta-mini,.hero-promise{box-shadow:none;background:#fff;border:1px solid #ccc}
  h2,h3{page-break-after:avoid}
  table,.table-wrap{page-break-inside:avoid}
}
{% block extra_css %}{% endblock %}
</style>
</head>
<body class="{% block body_class %}{% endblock %}">
<div class="topbar"></div>

<div class="nav-shell" id="nav-shell">
  <div class="nav">
    <a href="index.html" class="brand-mark">
      <span class="dot" aria-hidden="true"></span>
      <span class="name">{{ site.brand.name }}<small>{{ site.brand.tagline }}</small></span>
    </a>
    <div class="nav-links">
      {% for n in site.nav -%}
      <a href="{{ n.href }}"{% if n.href == this_page %} class="on" aria-current="page"{% endif %}>{{ n.label }}</a>
      {% endfor -%}
      <a href="{{ site.cta.href }}" class="nav-cta">{{ site.cta.label }}</a>
    </div>
  </div>
</div>

<main>
{% block content %}{% endblock %}
</main>

<section class="band band-dark cta-band">
  <div class="wrap-narrow">
    <h2>{% block bottom_cta_h2 %}Want a written quote you can actually trust?{% endblock %}</h2>
    <p class="lede">{% block bottom_cta_lede %}Text us a couple of photos and a sentence about what you want done. We'll have a real number in your inbox within 24 hours — and no, we won't call you twenty times after.{% endblock %}</p>
    <div class="cta-cluster center">
      <a href="{{ site.cta.href }}" class="btn btn-primary">{{ site.cta.label }}</a>
      <span class="cta-micro">{{ site.cta.microcopy }}</span>
    </div>
  </div>
</section>

<footer class="site">
  <div class="row">
    <div class="meta">
      <strong>{{ site.brand.name }}</strong>
      <span>{{ site.brand.city }}</span>
      <span><a href="tel:{{ site.brand.phone_tel }}">{{ site.brand.phone_display }}</a> · <a href="mailto:{{ site.brand.email }}">{{ site.brand.email }}</a></span>
    </div>
    <div class="links">
      {% for l in site.footer.legal_links -%}
      <a href="{{ l.href }}">{{ l.label }}</a>
      {% endfor %}
    </div>
    <div class="credit">
      <span>{{ site.footer.business_line }}</span>
      <span>{{ site.footer.copyright | safe }}</span>
    </div>
  </div>
</footer>

<script>
(function(){
  var nav = document.getElementById('nav-shell');
  if(!nav) return;
  var ticking = false;
  function update(){
    nav.classList.toggle('scrolled', window.scrollY > 8);
    ticking = false;
  }
  window.addEventListener('scroll', function(){
    if(!ticking){ requestAnimationFrame(update); ticking = true; }
  }, {passive:true});
  update();
})();
</script>
</body>
</html>
